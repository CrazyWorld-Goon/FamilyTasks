{
  "name": "dom-i-zadachi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,vite -c blue,magenta \"node server/api.mjs\" \"vite\"",
    "start": "cross-env NODE_ENV=production node server/api.mjs",
    "build": "vite build",
    "build:psite": "vite build --base=/dom-i-zadachi/ && node scripts/sync-to-psite.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "~5.6.2",
    "vite": "^5.4.10"
  }
}
